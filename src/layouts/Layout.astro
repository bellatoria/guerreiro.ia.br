<!doctype html>
---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { title = "Guerreiro.IA | Victor Guerreiro", description = "Pesquisa aplicada, sistemas inteligentes e consultoria em IA para problemas reais." } = Astro.props;
---

<html lang="pt-br">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <Header />
    <main class="mx-auto flex min-h-[calc(100vh-148px)] w-full max-w-6xl flex-col justify-center px-6 pb-12 pt-8 sm:px-8 lg:px-10">
      <slot />
    </main>
    <Footer />
  </body>
</html>
