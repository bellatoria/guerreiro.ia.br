---
import Layout from "../layouts/Layout.astro";
import { getSiteCopy } from "../lib/site";

const locale = "pt";
const copy = getSiteCopy(locale);
---

<Layout title="Engajamentos | Guerreiro.IA" description="Formatos de trabalho de Victor Guerreiro para diagnóstico técnico, arquitetura e consultoria aplicada em IA." locale={locale}>
  <section class="animate-fadeIn">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs uppercase tracking-[0.24em] text-accent">{copy.engagements.eyebrow}</p>
      <h1 class="mt-4 text-4xl font-semibold text-slate-50 sm:text-5xl">{copy.engagements.title}</h1>
      <p class="mt-5 text-base leading-8 text-slate-300">{copy.engagements.intro}</p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {copy.engagements.offers.map((offer) => (
        <article class="surface rounded-[1.75rem] p-6">
          <h2 class="text-2xl font-semibold text-slate-50">{offer.title}</h2>
          <p class="mt-3 text-sm leading-7 text-slate-300">{offer.body}</p>
        </article>
      ))}
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
      <section class="surface rounded-[1.75rem] p-6">
        <h2 class="text-2xl font-semibold text-slate-50">{copy.engagements.fitTitle}</h2>
        <ul class="mt-5 space-y-4 text-sm leading-7 text-slate-300">
          {copy.engagements.fitItems.map((item) => (
            <li class="rounded-2xl border border-white/8 bg-white/[0.03] px-4 py-3">{item}</li>
          ))}
        </ul>
      </section>

      <section class="surface rounded-[1.75rem] p-6">
        <h2 class="text-2xl font-semibold text-slate-50">{copy.engagements.processTitle}</h2>
        <div class="mt-5 space-y-4">
          {copy.engagements.processItems.map((step) => (
            <div class="rounded-2xl border border-white/8 bg-white/[0.03] p-4">
              <h3 class="text-lg font-semibold text-slate-100">{step.title}</h3>
              <p class="mt-2 text-sm leading-7 text-slate-300">{step.body}</p>
            </div>
          ))}
        </div>
      </section>
    </div>

    <section class="mt-6 surface rounded-[1.75rem] p-6">
      <h2 class="text-2xl font-semibold text-slate-50">{copy.engagements.notFitTitle}</h2>
      <ul class="mt-5 grid gap-4 md:grid-cols-3 text-sm leading-7 text-slate-300">
        {copy.engagements.notFitItems.map((item) => (
          <li class="rounded-2xl border border-white/8 bg-white/[0.03] px-4 py-3">{item}</li>
        ))}
      </ul>
    </section>

    <section class="mt-6 surface rounded-[1.75rem] p-6 sm:p-7">
      <p class="text-xs uppercase tracking-[0.24em] text-accent">Próximo passo</p>
      <div class="mt-4 grid gap-5 lg:grid-cols-[1fr_auto] lg:items-end">
        <div>
          <h2 class="text-3xl font-semibold text-slate-50">Se fizer sentido, me escreva com o problema, contexto e urgência.</h2>
          <p class="mt-3 max-w-3xl text-base leading-8 text-slate-300">
            A melhor primeira mensagem é curta e concreta: qual é a decisão difícil, o que já existe hoje e por que isso importa agora.
          </p>
        </div>
        <a href="mailto:contato@guerreiro.ia.br?subject=Conversa%20sobre%20engajamento%20em%20IA" class="cta-primary inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-medium uppercase tracking-[0.22em]">
          Abrir conversa
        </a>
      </div>
    </section>
  </section>
</Layout>
