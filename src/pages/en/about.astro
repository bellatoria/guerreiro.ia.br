---
import Layout from "../../layouts/Layout.astro";
import { getSiteCopy } from "../../lib/site";

const locale = "en";
const copy = getSiteCopy(locale);
---

<Layout title="About | Guerreiro.IA" description="Trajectory, technical focus, and positioning of Victor Guerreiro in applied research and AI consulting." locale={locale}>
  <section class="mx-auto grid max-w-5xl gap-8 lg:grid-cols-[0.85fr_1.15fr]">
    <div class="surface animate-fadeIn rounded-[2rem] p-7">
      <p class="text-xs uppercase tracking-[0.24em] text-accent">{copy.about.eyebrow}</p>
      <h1 class="mt-4 text-4xl font-semibold text-slate-50">{copy.about.title}</h1>
      {copy.about.paragraphs.map((paragraph) => (
        <p class="mt-5 text-base leading-8 text-slate-300">{paragraph}</p>
      ))}
    </div>

    <div class="animate-fadeIn space-y-6">
      <div class="surface rounded-[2rem] p-7">
        <p class="text-xs uppercase tracking-[0.24em] text-slate-400">{copy.offer.eyebrow}</p>
        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          {copy.about.blocks.map((block) => (
            <div>
              <h2 class="text-lg font-semibold text-slate-100">{block.title}</h2>
              <p class="mt-2 text-sm leading-7 text-slate-300">{block.body}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="surface rounded-[2rem] p-7">
        <p class="text-xs uppercase tracking-[0.24em] text-slate-400">{copy.about.principleEyebrow}</p>
        <p class="display-title mt-4 text-3xl italic text-accent">{copy.about.principleTitle}</p>
        <p class="mt-3 text-sm leading-7 text-slate-300">{copy.about.principleBody}</p>
      </div>
    </div>
  </section>
</Layout>
