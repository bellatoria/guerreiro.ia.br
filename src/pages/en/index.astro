---
import Layout from "../../layouts/Layout.astro";
import { getSiteCopy } from "../../lib/site";

const locale = "en";
const copy = getSiteCopy(locale);
---

<Layout title="Guerreiro.IA | Victor Guerreiro" description="Victor Guerreiro builds intelligent systems, recommendation logic, and technical AI consulting for real-world problems." locale={locale}>
  <section class="grid items-start gap-8 lg:grid-cols-[1.12fr_0.88fr] lg:gap-14">
    <div class="animate-fadeIn">
      <div class="pill animate-shimmer inline-flex rounded-full px-4 py-2 text-xs uppercase tracking-[0.26em] text-accent">
        {copy.hero.eyebrow}
      </div>

      <h1 class="mt-6 max-w-4xl text-5xl font-semibold leading-[0.95] text-slate-50 sm:text-6xl lg:text-7xl">
        {copy.hero.title}
        <span class="display-title italic text-accent"> {copy.hero.accent} </span>
        {copy.hero.titleSuffix}
      </h1>

      <p class="mt-6 max-w-2xl text-lg leading-8 text-muted sm:text-xl">
        {copy.hero.summary}
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href="/en/engagements" class="cta-primary inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-medium uppercase tracking-[0.22em]">
          See engagement formats
        </a>
        <a href="mailto:contato@guerreiro.ia.br?subject=Conversation%20about%20applied%20AI" class="cta-secondary inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-medium uppercase tracking-[0.22em]">
          {copy.ctaContact}
        </a>
        <a href="/en/projects" class="cta-secondary inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-medium uppercase tracking-[0.22em]">
          {copy.ctaProjects}
        </a>
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-3">
        {copy.hero.metrics.map((item) => (
          <div class="surface rounded-[1.5rem] p-4">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-400">{item.label}</p>
            <p class="mt-2 text-sm leading-6 text-slate-200">{item.value}</p>
          </div>
        ))}
      </div>
    </div>

    <aside class="animate-fadeIn surface relative overflow-hidden rounded-[2rem] p-6 sm:p-8">
      <div class="absolute right-0 top-0 h-44 w-44 rounded-full bg-[radial-gradient(circle,rgba(139,246,209,0.24),transparent_70%)]"></div>
      <img src="/perfil.jpg" alt="Victor Guerreiro portrait" class="relative z-10 mx-auto h-36 w-36 rounded-[2rem] border border-white/10 object-cover shadow-[0_18px_50px_rgba(0,0,0,0.35)] sm:h-44 sm:w-44" />

      <div class="relative z-10 mt-8 space-y-5 text-left">
        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-slate-400">{copy.hero.panelEyebrow}</p>
          <h2 class="mt-2 text-3xl font-semibold text-slate-50">{copy.hero.panelTitle}</h2>
          <p class="mt-3 text-base leading-7 text-slate-300">{copy.hero.panelBody}</p>
        </div>

        <div class="grid gap-3 text-sm text-slate-300">
          {copy.hero.panelItems.map((item) => (
            <div class="rounded-2xl border border-white/8 bg-white/[0.03] p-4">
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500">{item.label}</p>
              <p class="mt-2 font-medium text-slate-100">{item.value}</p>
            </div>
          ))}
        </div>
      </div>
    </aside>
  </section>

  <section class="mt-16 animate-fadeIn">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs uppercase tracking-[0.24em] text-accent">{copy.offer.eyebrow}</p>
      <h2 class="mt-4 text-4xl font-semibold text-slate-50 sm:text-5xl">{copy.offer.title}</h2>
      <p class="mt-5 text-base leading-8 text-slate-300">{copy.offer.intro}</p>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {copy.offer.cards.map((card) => (
        <article class="surface rounded-[1.75rem] p-6">
          <h3 class="text-2xl font-semibold text-slate-50">{card.title}</h3>
          <p class="mt-3 text-sm leading-7 text-slate-300">{card.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mt-16 animate-fadeIn">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs uppercase tracking-[0.24em] text-accent">{copy.proof.eyebrow}</p>
      <h2 class="mt-4 text-4xl font-semibold text-slate-50 sm:text-5xl">{copy.proof.title}</h2>
      <p class="mt-5 text-base leading-8 text-slate-300">{copy.proof.intro}</p>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {copy.proof.items.map((item) => (
        <article class="surface rounded-[1.75rem] p-6">
          <p class="text-xs uppercase tracking-[0.24em] text-accent">{item.label}</p>
          <p class="mt-4 text-lg leading-8 text-slate-100">{item.value}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mt-16 animate-fadeIn">
    <div class="surface mx-auto max-w-5xl rounded-[2rem] p-7 sm:p-8">
      <p class="text-xs uppercase tracking-[0.24em] text-accent">{copy.contact.eyebrow}</p>
      <div class="mt-4 grid gap-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
        <div>
          <h2 class="text-4xl font-semibold text-slate-50">{copy.contact.title}</h2>
          <p class="mt-4 max-w-2xl text-base leading-8 text-slate-300">{copy.contact.body}</p>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row lg:justify-end">
          <a href="mailto:contato@guerreiro.ia.br?subject=Conversation%20about%20applied%20AI" class="cta-primary inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-medium uppercase tracking-[0.22em]">
            {copy.contact.primary}
          </a>
          <a href="/en/engagements" class="cta-secondary inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-medium uppercase tracking-[0.22em]">
            Engagements
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
