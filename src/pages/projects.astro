---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
---

<Layout title="Projetos | Guerreiro.IA" description="Projetos em destaque de Victor Guerreiro em sistemas de recomendação, serviços públicos e modelagem aplicada.">
  <section class="animate-fadeIn">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs uppercase tracking-[0.24em] text-accent">Projetos em destaque</p>
      <h1 class="mt-4 text-4xl font-semibold text-slate-50 sm:text-5xl">Alguns sistemas e contextos onde técnica virou entrega.</h1>
      <p class="mt-5 text-base leading-8 text-slate-300">Uma seleção de trabalhos em que recomendação, modelagem e arquitetura ajudaram a resolver problemas reais.</p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      <Card
        title="Sistema de Recomendação Famyle"
        description="Matching inteligente entre empregadores e profissionais domésticos, com extração de habilidades e ranking multiobjetivo orientado a aderência real."
        link="https://famyle.com"
      />
      <Card
        title="Expresso Goiás"
        description="Recomendações personalizadas de serviços públicos no Portal Expresso, combinando popularidade, personalização e critérios de fairness."
        link="https://www.go.gov.br/"
      />
      <Card
        title="Gema Elétrica"
        description="Modelos preditivos para estimativa de custo e esforço em projetos de engenharia elétrica, aproximando decisão comercial e execução técnica."
        link="https://www.lembry.com/"
      />
    </div>
  </section>
</Layout>
